<Application x:Class="CourierSystemWPF.App"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CourierSystemWPF"
        xmlns:vm="clr-namespace:CourierSystemWPF.ViewModels"
        xmlns:views="clr-namespace:CourierSystemWPF.Views"
        StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:LoginVM}">
                <views:Login />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:HomeVM}">
                <views:Home />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:CredentialsVM}">
                <views:Credentials />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:CredentialsViewVM}">
                <views:CredentialsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:CredentialsAddVM}">
                <views:CredentialsAdd />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:NewClientVM}">
                <views:NewClient />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ContractsVM}">
                <views:Contracts />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ContractAddVM}">
                <views:ContractAdd />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ContractsViewVM}">
                <views:ContractsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ClientViewVM}">
                <views:ClientView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DeliveriesVM}">
                <views:Deliveries/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DeliveriesAddVM}">
                <views:DeliveriesAdd/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DeliveriesPersonalVM}">
                <views:DeliveriesPersonal/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DeliveriesViewVM}">
                <views:DeliveriesView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ReportsVM}">
                <views:Reports/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ReportDailyVM}">
                <views:ReportDaily/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ReportMonthlyVM}">
                <views:ReportMonthly/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ReportRevenueVM}">
                <views:ReportRevenue/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:EmployeesVM}">
                <views:Employees/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>

</Application>

    

