<UserControl x:Class="CourierSystemWPF.Views.ClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="229*"/>
            <ColumnDefinition Width="171*"/>
        </Grid.ColumnDefinitions>

        <!-- DataGrid -->
        <DataGrid ItemsSource="{Binding Clients}" 
                  SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  EnableRowVirtualization="False"
        >

            <DataGrid.Resources>
                <Style x:Key="WrapTextBlockStyle" TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="Auto"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="First Name" Binding="{Binding firstName}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Last Name" Binding="{Binding lastName}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding email}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding phoneNumber}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Business" Binding="{Binding businessName}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Editor Panel -->
        <Grid Background="#FF90C0EA" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="101*"/>
                <ColumnDefinition Width="173*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="90*"/>
                <RowDefinition Height="265*"/>
                <RowDefinition Height="61*"/>
                <RowDefinition Height="34*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Label Content="Client Editor"
                   Grid.ColumnSpan="2"
                   Background="#00000000"
                   Foreground="#FF1B3D69"
                   FontSize="24"
                   FontFamily="Cascadia Mono SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

            <!-- Inputs -->
            <StackPanel Grid.Row="1" Grid.Column="1">
                <TextBox Text="{Binding IDInput}" Margin="20,20,20,0" Padding="3" IsReadOnly="True"/>
                <TextBox Text="{Binding FirstName}" Margin="20,20,20,0" Padding="3"/>
                <TextBox Text="{Binding LastName}" Margin="20,20,20,0" Padding="3"/>
                <TextBox Text="{Binding Email}" Margin="20,20,20,0" Padding="3"/>
                <TextBox Text="{Binding PhoneNumber}" Margin="20,20,20,0" Padding="3"/>
                <TextBox Text="{Binding BusinessName}" Margin="20,20,20,0" Padding="3"/>
            </StackPanel>

            <!-- Labels -->
            <StackPanel Grid.Row="1" Grid.Column="0">
                <Label Content="ID:" Margin="0,19,0,0" Padding="3" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="First Name:" Margin="0,19,0,0" Padding="3" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="Last Name:" Margin="0,19,0,0" Padding="3" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="Email:" Margin="0,19,0,0" Padding="3" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="Phone:" Margin="0,19,0,0" Padding="3" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="Business:" Margin="0,19,0,0" Padding="3" Background="#00000000" Foreground="White" FontSize="14"/>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="2" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150*"/>
                    <ColumnDefinition Width="150*"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding DeleteCommand}" Content="Delete" Grid.Column="0" Margin="15"/>
                <Button Command="{Binding UpdateCommand}" Content="Update" Grid.Column="1" Margin="15"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>