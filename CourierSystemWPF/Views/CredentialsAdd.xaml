<UserControl x:Class="CourierSystemWPF.Views.CredentialsAdd"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CourierSystemWPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300*"/>
            <ColumnDefinition Width="300*"/>
            <ColumnDefinition Width="300*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="90*"/>
            <RowDefinition Height="265*"/>
            <RowDefinition Height="61*"/>
            <RowDefinition Height="34*"/>
        </Grid.RowDefinitions>

        <Label Content="Add new credential" Grid.ColumnSpan="3" Background="#00000000" Foreground="#FF1B3D69" FontSize="24" FontFamily="Cascadia Mono SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="1">
            <TextBox Text="{Binding UsernameInput}" Margin="20,20,20,0" Padding="5"/>
            <TextBox Text="{Binding PasswordInput}" Margin="20,20,20,0" Padding="5"/>
            <TextBox Text="{Binding AccessLevelInput}" Margin="20,20,20,0" Padding="5"/>
            <TextBox Text="{Binding EmployeeIDInput}" Margin="20,20,20,0" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0">
            <Label Content="Username:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
            <Label Content="Password:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
            <Label Content="Access Level:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
            <Label Content="EmployeeID:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
        </StackPanel>


        <Button  Command="{Binding UpdateCommand}" Content="Add"  Grid.Column="1" Grid.Row="2" Margin="15,15,15,15"/>
    </Grid>
</UserControl>
