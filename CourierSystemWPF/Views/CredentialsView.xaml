<UserControl x:Class="CourierSystemWPF.Views.CredentialsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CourierSystemWPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="229*"/>
            <ColumnDefinition Width="171*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <DataGrid ItemsSource="{Binding Logins}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}"/>
                <DataGridTextColumn Header="Username" Binding="{Binding username}"/>
                <DataGridTextColumn Header="Password" Binding="{Binding password}"/>
                <DataGridTextColumn Header="Access Level" Binding="{Binding accessLevel}"/>
                <DataGridTextColumn Header="Employee ID" Binding="{Binding employeeId}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Selected view area -->
        <Grid Background="#FF90C0EA" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="101*"/>
                <ColumnDefinition Width="173*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="90*"/>
                <RowDefinition Height="265*"/>
                <RowDefinition Height="61*"/>
                <RowDefinition Height="34*"/>
            </Grid.RowDefinitions>

            <Label Content="Credential Editor" Grid.ColumnSpan="2" Background="#00000000" Foreground="#FF1B3D69" FontSize="24" FontFamily="Cascadia Mono SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel Grid.Row="1" Grid.Column="1">
                <TextBox Text="{Binding CredentialIDInput}" Margin="20,20,20,0" Padding="5" IsReadOnly="True"/>
                <TextBox Text="{Binding UsernameInput}" Margin="20,20,20,0" Padding="5"/>
                <TextBox Text="{Binding PasswordInput}" Margin="20,20,20,0" Padding="5"/>
                <TextBox Text="{Binding AccessLevelInput}" Margin="20,20,20,0" Padding="5"/>
                <TextBox Text="{Binding EmployeeIDInput}" Margin="20,20,20,0" Padding="5"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0">
                <Label Content="ID:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="Username:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="Password:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="Access Level:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="White" FontSize="14"/>
                <Label Content="EmployeeID:" Margin="0,17,0,0" Padding="5" Background="#00000000" Foreground="White" FontSize="14"/>
            </StackPanel>

            <Grid Grid.Row="2" Grid.ColumnSpan="2" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150*"/>
                    <ColumnDefinition Width="150*"/>
                </Grid.ColumnDefinitions>
                <Button  Command="{Binding DeleteCommand}" Content="Delete"  Grid.Column="0" Margin="15"/>
                <Button  Command="{Binding UpdateCommand}" Content="Update"  Grid.Column="1" Margin="15"/>
            </Grid>
        </Grid>

    </Grid>
</UserControl>
