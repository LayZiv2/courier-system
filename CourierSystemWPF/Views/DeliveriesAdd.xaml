<UserControl x:Class="CourierSystemWPF.Views.DeliveriesAdd"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="128*"/>
            <ColumnDefinition Width="294*"/>
            <ColumnDefinition Width="49*"/>
            <ColumnDefinition Width="329*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="90*"/>
            <RowDefinition Height="265*"/>
            <RowDefinition Height="61*"/>
            <RowDefinition Height="34*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Label Content="Add new delivery"
               Background="#00000000"
               Foreground="#FF1B3D69"
               FontSize="24"
               FontFamily="Cascadia Mono SemiBold"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
               Grid.Column="0"
               Grid.ColumnSpan="2"
               Margin="40,0,0,0"/>

        <!-- Inputs -->
        <StackPanel Grid.Row="1" Grid.Column="1">
            <xctk:DateTimePicker Margin="20,20,20,0" Padding="5" Value="{Binding DeliveryDateTime}"/>

            <ComboBox Margin="20,20,20,0" Padding="5"
                      ItemsSource="{Binding Couriers}"
                      SelectedItem="{Binding SelectedCourier}"
                      DisplayMemberPath="id"/>

            <!-- Optional Contract -->
            <ComboBox Margin="20,20,20,0" Padding="5"
                      ItemsSource="{Binding Contracts}"
                      SelectedItem="{Binding SelectedContract}"
                      DisplayMemberPath="id"/>

            <TextBlock Text="(Leave blank if no contract)"
                       Margin="20,5,20,0"
                       FontSize="11"
                       Foreground="Gray"/>

            <TextBox Margin="20,20,20,0" Padding="5"
                     Text="{Binding DestinationAddress}"/>

            <CheckBox Content="Delivered"
                      Margin="20,20,20,0"
                      IsChecked="{Binding Delivered}"/>
        </StackPanel>

        <!-- Labels -->
        <StackPanel Grid.Row="1" Grid.Column="0">
            <Label Content="Date:" Margin="0,19,0,0" Padding="5" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
            <Label Content="Courier ID:" Margin="0,19,0,0" Padding="5" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
            <Label Content="Contract ID:" Margin="0,19,0,0" Padding="5" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
            <Label Content="Address:" Margin="0,19,0,0" Padding="5" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
            <Label Content="Status:" Margin="0,19,0,0" Padding="5" Foreground="#FF3C3A3A" FontSize="14" HorizontalAlignment="Right"/>
        </StackPanel>

        <!-- Button -->
        <Button Command="{Binding AddCommand}"
                Content="Add"
                Grid.Column="1"
                Grid.Row="2"
                Margin="15"/>
    </Grid>
</UserControl>