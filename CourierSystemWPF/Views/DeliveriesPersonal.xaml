<UserControl x:Class="CourierSystemWPF.Views.DeliveriesPersonal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CourierSystemWPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="74*"/>
            <RowDefinition Height="271*"/>
            <RowDefinition Height="66*"/>
            <RowDefinition Height="39*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="41*"/>
            <ColumnDefinition Width="300*"/>
            <ColumnDefinition Width="25*"/>
            <ColumnDefinition Width="300*"/>
            <ColumnDefinition Width="58*"/>
        </Grid.ColumnDefinitions>

        <Label Content="Assigned Jobs" Grid.Row="0" Grid.Column="1" FontFamily="Cascadia Mono" FontSize="24" VerticalAlignment="Bottom" Foreground="#FF212C69"/>
        <Label Content="Accepted Jobs" Grid.Row="0" Grid.Column="3" FontFamily="Cascadia Mono" FontSize="24" VerticalAlignment="Bottom" Foreground="#FF212C69"/>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <Button Content="Accept Job" Margin="15" Command="{Binding AcceptCommand}"/>
            <Button Content="Decline Job" Margin="15" Command="{Binding DeclineCommand}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal">
            <Button Content="Mark As Complete" Margin="15" Command="{Binding CompleteCommand}"/>
        </StackPanel>

        <!-- Assigned Datagrid -->
        <DataGrid ItemsSource="{Binding AssingedDeliveries}" 
                  SelectedItem="{Binding SelectedAssignedItem}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  EnableRowVirtualization="False"
                  Grid.Row="1"
                  Grid.Column="1"
                  >

            <DataGrid.Resources>
                <Style x:Key="WrapTextBlockStyle" TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="Auto"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Address" Binding="{Binding destinationAddress}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Delivery Date" Binding="{Binding deliveryDateTime}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Contract ID" Binding="{Binding contractId}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Delivered" Binding="{Binding delivered}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Courier ID" Binding="{Binding courierId}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Accepted" Binding="{Binding accepted}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Accepted Datagrid -->
        <DataGrid ItemsSource="{Binding AcceptedDeliveries}" 
                  SelectedItem="{Binding SelectedAcceptedItem}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  EnableRowVirtualization="False"
                  Grid.Row="1"
                  Grid.Column="3"
                  >

            <DataGrid.Resources>
                <Style x:Key="WrapTextBlockStyle" TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="Auto"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Address" Binding="{Binding destinationAddress}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Delivery Date" Binding="{Binding deliveryDateTime}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Contract ID" Binding="{Binding contractId}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Delivered" Binding="{Binding delivered}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Courier ID" Binding="{Binding courierId}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
                <DataGridTextColumn Header="Accepted" Binding="{Binding accepted}" ElementStyle="{StaticResource WrapTextBlockStyle}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
