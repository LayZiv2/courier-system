<UserControl  x:Class="CourierSystemWPF.Views.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CourierSystemWPF.Views"
      xmlns:vm="clr-namespace:CourierSystemWPF.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*"/>
            <ColumnDefinition Width="25*"/>
            <ColumnDefinition Width="25*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="201*"/>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="90*"/>
            <RowDefinition Height="100*"/>
        </Grid.RowDefinitions>

        <Label Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Height="25" Width="122">Courier System Login</Label>

        <TextBox Name="usernameTxt" Grid.Row="1" Grid.Column="1" Text="{Binding UsernameInput}"/>
        <TextBox Name="passwordTxt" Grid.Row="3" Grid.Column="1" Text="{Binding PasswordInput}"/>

        <Button Grid.Column="1" Grid.Row="4" Margin="75,10,75,50" Command="{Binding LoginCommand}">Login</Button>
        
        <Label Grid.Column="1" Grid.Row="5" VerticalAlignment="Center" HorizontalAlignment="Center" Content="{Binding StatusText}"/>
    </Grid>
</UserControl>
